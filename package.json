{
  "name": "@arielgonzaguer/michi-router",
  "private": false,
  "version": "3.3.0",
  "description": "El router minimalista y simple para React.\nEl objetivo principal de esta herramienta es proporcionar la funcionalidad básica de enrutamiento.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./protected": {
      "types": "./dist/protected.d.ts",
      "import": "./dist/protected.mjs",
      "require": "./dist/protected.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build:bundle",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "pnpm run clean",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "build:bundle": "pnpm run clean && tsup src/index.ts src/core.ts src/protected.ts --format esm,cjs --minify --dts --out-dir dist --external react --splitting false",
    "size:check": "node scripts/check-size.js",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "pnpm run build:bundle && pnpm test && pnpm run size:check",
    "release:patch": "pnpm version patch && pnpm publish --access public && git push origin main --tags",
    "release:minor": "pnpm version minor && pnpm publish --access public && git push origin main --tags",
    "release:major": "pnpm version major && pnpm publish --access public && git push origin main --tags"
  },
  "keywords": [
    "enrutado",
    "react",
    "router",
    "typescript",
    "michi",
    "cats",
    "gatos",
    "front-end"
  ],
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "1.13.5",
    "@testing-library/jest-dom": "6.0.0",
    "@testing-library/react": "14.0.0",
    "@types/jest": "29.5.3",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "26.1.0",
    "prettier": "^3.9.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.0.1",
    "tsup": "8.5.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ariel-GonzAguer/michi-router.git"
  },
  "bugs": {
    "url": "https://github.com/Ariel-GonzAguer/michi-router/issues"
  },
  "homepage": "https://github.com/Ariel-GonzAguer/michi-router#readme",
  "author": "Ariel Gonzales Agüero",
  "license": "MIT"
}